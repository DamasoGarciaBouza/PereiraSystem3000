; --- DEBUG WOOD ---
(defrule(goal debugWood 1)=>(enable-timer 1 30)(disable-self))
(defrule(timer-triggered 1)=>
    (disable-timer 1)
    (enable-timer 1 60)
    (up-chat-data-to-self "Wood drop distance: %d" s: sn-maximum-wood-drop-distance)
)

; --- DEBUG FOOD ---
(defrule(goal debugFood 1)=>(enable-timer 2 30)(disable-self))
(defrule(timer-triggered 2)=>
    (disable-timer 2)
    (enable-timer 2 60)
    (up-chat-data-to-self "Food drop distance: %d" s: sn-maximum-food-drop-distance)
)

